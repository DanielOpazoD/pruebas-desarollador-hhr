rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ============================================
    // HELPER FUNCTIONS
    // ============================================
    
    // Check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Get user email
    function getUserEmail() {
      return request.auth.token.email;
    }

    // Check if authenticated user has an email claim
    function hasEmail() {
      return isAuthenticated() && request.auth.token.email != null;
    }

    function isBootstrapAdmin() {
      return hasEmail() &&
             getUserEmail() in [
               'daniel.opazo@hospitalhangaroa.cl',
               'd.opazo.damiani@gmail.com'
             ];
    }

	    function getConfiguredRole() {
	      return hasEmail() &&
	             exists(/databases/$(database)/documents/config/roles)
	        ? normalizeRole(get(/databases/$(database)/documents/config/roles).data[getUserEmail()])
	        : null;
	    }

	    function normalizeRole(role) {
	      return role == 'viewer_census'
	        ? 'viewer'
	        : role;
	    }

	    function getClaimRole() {
	      return isAuthenticated() &&
	             request.auth.token.keys().hasAny(['role']) &&
	             request.auth.token.role != null
	        ? normalizeRole(request.auth.token.role)
	        : null;
	    }

	    function getEffectiveRole() {
	      return getClaimRole() != null
	        ? getClaimRole()
	        : getConfiguredRole();
	    }
	    
	    function isAdmin() {
	      return isAuthenticated() && (
	        isBootstrapAdmin() ||
	        getEffectiveRole() == 'admin'
	      );
	    }
	    
	    function isNurse() {
	      return isAuthenticated() && (
	        isAdmin() ||
	        getEffectiveRole() == 'nurse_hospital'
	      );
	    }

	    function isDoctor() {
	      return isAuthenticated() && (
	        isAdmin() ||
	        getEffectiveRole() == 'doctor_urgency'
	      );
	    }

	    function isDoctorSpecialist() {
	      return isAuthenticated() && (
	        isAdmin() ||
	        getEffectiveRole() == 'doctor_specialist'
	      );
	    }
    
    // Check if user can edit (admin or nurse)
    function canEdit() {
      return isAdmin() || isNurse();
    }

    function canReportSystemHealth() {
      return isAdmin() || isNurse();
    }

	    function isEditorRole() {
	      return isAuthenticated() && (
	        getEffectiveRole() == 'editor'
	      );
	    }

    function isValidSpecialistClinicalCribMedicalUpdate(beforeCrib, afterCrib) {
      return beforeCrib != null &&
             afterCrib != null &&
             afterCrib.diff(beforeCrib).affectedKeys().hasOnly([
               'medicalHandoffEntries',
               'medicalHandoffNote',
               'medicalHandoffAudit',
               'clinicalEvents'
             ]);
    }

    function isValidSpecialistMedicalBedUpdate(bedId) {
      let beforeBed = resource.data.beds[bedId];
      let afterBed = request.resource.data.beds[bedId];
      let affectedBedKeys = afterBed.diff(beforeBed).affectedKeys();

      return beforeBed != null &&
             afterBed != null &&
             affectedBedKeys.hasOnly([
               'medicalHandoffEntries',
               'medicalHandoffNote',
               'medicalHandoffAudit',
               'clinicalEvents',
               'clinicalCrib'
             ]) &&
             (
               !affectedBedKeys.hasAny(['clinicalCrib']) ||
               isValidSpecialistClinicalCribMedicalUpdate(beforeBed.clinicalCrib, afterBed.clinicalCrib)
             );
    }

    function isOnlySpecialistAffectedBed(affectedBedIds, bedId) {
      return affectedBedIds.size() == 1 &&
             affectedBedIds.hasOnly([bedId]) &&
             isValidSpecialistMedicalBedUpdate(bedId);
    }

    function isSpecialistMedicalHandoffUpdate() {
      let affectedRecordKeys = request.resource.data.diff(resource.data).affectedKeys();
      let affectedBedIds = request.resource.data.beds.diff(resource.data.beds).affectedKeys();
      let now = request.time.toMillis();
      let currentRecordTimestamp = resource.data.dateTimestamp;
      let nextRecordTimestamp = request.resource.data.dateTimestamp;
      let effectiveRecordTimestamp =
        nextRecordTimestamp != null
          ? nextRecordTimestamp
          : currentRecordTimestamp;

      return isDoctorSpecialist() &&
             effectiveRecordTimestamp != null &&
             now >= effectiveRecordTimestamp &&
             now < (effectiveRecordTimestamp + 86400000) &&
             affectedRecordKeys.hasOnly(['beds', 'lastUpdated', 'dateTimestamp']) &&
             (
               currentRecordTimestamp != null ||
               nextRecordTimestamp != null
             ) &&
             (
               isOnlySpecialistAffectedBed(affectedBedIds, 'R1') ||
               isOnlySpecialistAffectedBed(affectedBedIds, 'R2') ||
               isOnlySpecialistAffectedBed(affectedBedIds, 'R3') ||
               isOnlySpecialistAffectedBed(affectedBedIds, 'R4') ||
               isOnlySpecialistAffectedBed(affectedBedIds, 'NEO1') ||
               isOnlySpecialistAffectedBed(affectedBedIds, 'NEO2') ||
               isOnlySpecialistAffectedBed(affectedBedIds, 'H1C1') ||
               isOnlySpecialistAffectedBed(affectedBedIds, 'H1C2') ||
               isOnlySpecialistAffectedBed(affectedBedIds, 'H2C1') ||
               isOnlySpecialistAffectedBed(affectedBedIds, 'H2C2') ||
               isOnlySpecialistAffectedBed(affectedBedIds, 'H3C1') ||
               isOnlySpecialistAffectedBed(affectedBedIds, 'H3C2') ||
               isOnlySpecialistAffectedBed(affectedBedIds, 'H4C1') ||
               isOnlySpecialistAffectedBed(affectedBedIds, 'H4C2') ||
               isOnlySpecialistAffectedBed(affectedBedIds, 'H5C1') ||
               isOnlySpecialistAffectedBed(affectedBedIds, 'H5C2') ||
               isOnlySpecialistAffectedBed(affectedBedIds, 'H6C1') ||
               isOnlySpecialistAffectedBed(affectedBedIds, 'H6C2') ||
               isOnlySpecialistAffectedBed(affectedBedIds, 'E1') ||
               isOnlySpecialistAffectedBed(affectedBedIds, 'E2') ||
               isOnlySpecialistAffectedBed(affectedBedIds, 'E3') ||
               isOnlySpecialistAffectedBed(affectedBedIds, 'E4') ||
               isOnlySpecialistAffectedBed(affectedBedIds, 'E5')
             );
    }

    function isSpecialistClinicalDocumentDraftWrite() {
      return isDoctorSpecialist() &&
             request.resource.data.status == 'draft' &&
             (
               resource == null ||
               resource.data == null ||
               resource.data.status == 'draft'
             );
    }

	    function hasConfiguredRole() {
	      return getEffectiveRole() != null;
	    }

	    function isGeneralViewer() {
	      return isAuthenticated() && getEffectiveRole() == 'viewer';
	    }

    // Consolidated read access for clinical data
    function canReadClinicalData() {
      return isAdmin() ||
             isNurse() ||
             isDoctor() ||
             isDoctorSpecialist() ||
             isEditorRole() ||
             isGeneralViewer();
    }

    // System health payload guard:
    // - caller can only write own doc
    // - schema is constrained
    // - numeric counters are bounded to non-negative values
    function isValidSystemHealthWrite(userId) {
      let payload = request.resource.data;
      return isAuthenticated() &&
             request.auth.uid == userId &&
             payload.keys().hasOnly([
               'uid',
               'email',
               'displayName',
               'lastSeen',
               'isOnline',
               'isOutdated',
               'pendingMutations',
               'pendingSyncTasks',
               'failedSyncTasks',
               'conflictSyncTasks',
               'retryingSyncTasks',
               'oldestPendingAgeMs',
               'localErrorCount',
               'degradedLocalPersistence',
               'repositoryWarningCount',
               'slowestRepositoryOperationMs',
               'appVersion',
               'platform',
               'userAgent'
             ]) &&
             payload.uid == request.auth.uid &&
             (!('email' in payload) || payload.email == null || payload.email is string) &&
             (!('displayName' in payload) || payload.displayName == null || payload.displayName is string) &&
             (!('lastSeen' in payload) || payload.lastSeen == null || payload.lastSeen is string) &&
             (!('isOnline' in payload) || payload.isOnline == null || payload.isOnline is bool) &&
             (!('isOutdated' in payload) || payload.isOutdated == null || payload.isOutdated is bool) &&
             (!('pendingMutations' in payload) || payload.pendingMutations == null || (payload.pendingMutations is int && payload.pendingMutations >= 0 && payload.pendingMutations <= 10000)) &&
             (!('pendingSyncTasks' in payload) || payload.pendingSyncTasks == null || (payload.pendingSyncTasks is int && payload.pendingSyncTasks >= 0 && payload.pendingSyncTasks <= 10000)) &&
             (!('failedSyncTasks' in payload) || payload.failedSyncTasks == null || (payload.failedSyncTasks is int && payload.failedSyncTasks >= 0 && payload.failedSyncTasks <= 10000)) &&
             (!('conflictSyncTasks' in payload) || payload.conflictSyncTasks == null || (payload.conflictSyncTasks is int && payload.conflictSyncTasks >= 0 && payload.conflictSyncTasks <= 10000)) &&
             (!('retryingSyncTasks' in payload) || payload.retryingSyncTasks == null || (payload.retryingSyncTasks is int && payload.retryingSyncTasks >= 0 && payload.retryingSyncTasks <= 10000)) &&
             (!('oldestPendingAgeMs' in payload) || payload.oldestPendingAgeMs == null || (payload.oldestPendingAgeMs is int && payload.oldestPendingAgeMs >= 0 && payload.oldestPendingAgeMs <= 864000000)) &&
             (!('localErrorCount' in payload) || payload.localErrorCount == null || (payload.localErrorCount is int && payload.localErrorCount >= 0 && payload.localErrorCount <= 10000)) &&
             (!('degradedLocalPersistence' in payload) || payload.degradedLocalPersistence == null || payload.degradedLocalPersistence is bool) &&
             (!('repositoryWarningCount' in payload) || payload.repositoryWarningCount == null || (payload.repositoryWarningCount is int && payload.repositoryWarningCount >= 0 && payload.repositoryWarningCount <= 10000)) &&
             (!('slowestRepositoryOperationMs' in payload) || payload.slowestRepositoryOperationMs == null || (payload.slowestRepositoryOperationMs is int && payload.slowestRepositoryOperationMs >= 0 && payload.slowestRepositoryOperationMs <= 864000000)) &&
             (!('appVersion' in payload) || payload.appVersion == null || payload.appVersion is string) &&
             (!('platform' in payload) || payload.platform == null || payload.platform is string) &&
             (!('userAgent' in payload) || payload.userAgent == null || payload.userAgent is string);
    }
    
    // Check if a date (ms timestamp) is within the editing window (+/- 1 day)
    // Nurse window: Can edit yesterday, today and tomorrow.
    // Calculation: (CurrentTime - RecordTime) should be between -24h and +48h
    // If dateTimestamp is null (legacy record), allow the edit (grace mode)
    function isWithinEditingWindow(recordTS) {
      let now = request.time.toMillis();
      // Legacy records without dateTimestamp are allowed (they'll be fixed on save)
      return recordTS == null || (
             now > (recordTS - 86400000) && 
             now < (recordTS + 172800000)
      );
    }

    // Check if the update is only for medical signature fields
    function isMedicalUpdate() {
      let affectedKeys = request.resource.data.diff(resource.data).affectedKeys();
      return affectedKeys.hasOnly([
        'medicalSignature',
        'medicalSignatureByScope',
        'medicalHandoffDoctor',
        'medicalHandoffSentAt',
        'medicalHandoffSentAtByScope',
        'medicalSignatureLinkTokenByScope',
        'lastUpdated'
      ]);
    }
    
    // ============================================
    // HOSPITALS COLLECTION (Main hierarchy)
    // ============================================
    match /hospitals/{hospitalId} {
      // Hospital document itself
      allow read: if canReadClinicalData();
      allow write: if isAdmin();
      
      // ----------------------------------------
      // DAILY RECORDS (Census Data)
      // ----------------------------------------
      match /dailyRecords/{date} {
        allow read: if canReadClinicalData();
        // Create: Admin or Nurse
        allow create: if canEdit();
        // Update: Admin siempre, Enfermero en ventana, o Médico solo campos de firma
        allow update: if isAdmin() || 
                        (isNurse() && isWithinEditingWindow(resource.data.dateTimestamp)) ||
                        (isDoctor() && isMedicalUpdate()) ||
                        isSpecialistMedicalHandoffUpdate();
        // Delete: Admin only (nurses must not hard-delete census records)
        allow delete: if isAdmin();
        
        // History subcollection
        match /history/{historyId} {
          allow read: if canReadClinicalData();
          allow create: if canEdit();
          allow update, delete: if isAdmin();
        }
      }

      // Deleted Records (Trash)
      match /deletedRecords/{trashId} {
        allow read, write: if isAdmin();
      }
      
      // ----------------------------------------
      // CLINICAL DOCUMENTS
      // ----------------------------------------
      match /clinicalDocuments/{documentId} {
        allow read: if canReadClinicalData();
        allow create: if isAdmin() || isDoctor() || isSpecialistClinicalDocumentDraftWrite();
        allow update: if isAdmin() || isDoctor() || isSpecialistClinicalDocumentDraftWrite();
        allow delete: if isAdmin() || isDoctor() || isNurse() || isEditorRole();
      }

      // ----------------------------------------
      // CLINICAL DOCUMENT TEMPLATES
      // ----------------------------------------
      match /clinicalDocumentTemplates/{templateId} {
        allow read: if canReadClinicalData();
        allow write: if isAdmin();
      }

      // ----------------------------------------
      // SETTINGS (Nurses, TENS, TableConfig)
      // ----------------------------------------
      match /settings/{settingId} {
        allow read: if canReadClinicalData();
        // Allow both Admins and Nurses to update catalogs and settings
        allow write: if canEdit();
      }

      // ----------------------------------------
      // REMINDERS / STAFF NOTICES
      // ----------------------------------------
      match /reminders/{reminderId} {
        allow read: if canReadClinicalData();
        allow create, update, delete: if isAdmin();

	        match /readReceipts/{receiptId} {
	          allow read: if isAdmin() ||
	                       (isAuthenticated() && resource.data.userId == request.auth.uid);
	          allow create, update: if isAdmin() || (
	                                isAuthenticated() &&
	                                request.resource.data.userId == request.auth.uid &&
	                                request.resource.data.userName is string &&
	                                request.resource.data.readAt is string &&
	                                request.resource.data.shift in ['day', 'night'] &&
	                                request.resource.data.dateKey is string
	                              );
	          allow delete: if isAdmin();
	        }
      }
      
      // ----------------------------------------
      // EXPORT PASSWORDS
      // ----------------------------------------
      match /exportPasswords/{passwordId} {
        allow read: if canReadClinicalData();
        allow write: if isAdmin();
      }
      
      // ----------------------------------------
      // AUDIT LOGS (Hospital-level)
      // ----------------------------------------
      match /auditLogs/{logId} {
        allow read: if isAdmin();
        allow create: if canReadClinicalData();
        // Allow admins to update or delete during consolidation/maintenance
        allow update, delete: if isAdmin();
      }
      
      // ----------------------------------------
      // TRANSFER REQUESTS (Patient transfers)
      // ----------------------------------------
      match /transferRequests/{transferId} {
        allow read: if canReadClinicalData();
        allow create: if canEdit();
        allow update: if canEdit();
        allow delete: if isAdmin();
      }
      
      // ----------------------------------------
      // TRANSFER HISTORY (Completed transfers)
      // ----------------------------------------
      match /transferHistory/{transferId} {
        allow read: if canReadClinicalData();
        allow create: if canEdit();
        allow update, delete: if isAdmin();
      }
      
      // ----------------------------------------
      match /bookmarks/{bookmarkId} {
        allow read: if canReadClinicalData();
        allow write: if canReadClinicalData();
      }

      // ----------------------------------------
      // BACKUP FILES (Cloud backup archives)
      // ----------------------------------------
      match /backupFiles/{fileId} {
        allow read: if canReadClinicalData();
        allow create: if canEdit();
        allow update: if isAdmin();
        allow delete: if isAdmin();
      }

      // ----------------------------------------
      // PATIENT MASTER INDEX
      // ----------------------------------------
      match /patients/{rut} {
        allow read: if canReadClinicalData();
        allow write: if canEdit();
      }
    }
    
    // ============================================
    // TOP-LEVEL AUDIT LOGS (Legacy/Fallback)
    // ============================================
    match /auditLogs/{logId} {
      allow read: if isAdmin();
      allow create: if canReadClinicalData();
      // Allow admins to update or delete during consolidation/maintenance
      allow update, delete: if isAdmin();
    }
    
    // ============================================
    // ALLOWED USERS (Legacy retired)
    // ============================================
    match /allowedUsers/{userId} {
      allow read, write: if false;
    }
    
    // ============================================
    // STAFF CATALOGS (Legacy - if still used)
    // ============================================
    match /staffCatalogs/{catalogType} {
      allow read: if canReadClinicalData();
      allow write: if isAdmin();
    }
    
    // ============================================
    // USER SETTINGS
    // ============================================
    match /userSettings/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow write: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
    }
    
    // ============================================
    // WHATSAPP INTEGRATION
    // ============================================
    match /whatsapp/{docId} {
      allow read: if canReadClinicalData();
      allow write: if isAdmin();
    }
    
    match /whatsappLogs/{logId} {
      allow read: if isAdmin();
      allow create: if canReadClinicalData();
      allow update, delete: if false;
    }
    
    match /whatsappMessages/{messageId} {
      allow read, write: if isAdmin();
    }
    
    match /shifts/{path=**} {
      allow read: if canReadClinicalData();
      allow write: if isAdmin();
    }
    
    // ============================================
    // SYSTEM HEALTH
    // ============================================
    match /stats/system_health/users/{userId} {
      allow read: if canReportSystemHealth();
      allow create, update: if isValidSystemHealthWrite(userId);
      allow delete: if false;
    }

    // ============================================
    // SYSTEM CONFIGURATION
    // ============================================
    match /emailRecipientLists/{listId} {
      allow read: if canReadClinicalData();
      allow write: if canEdit() || isEditorRole();
    }

    match /config/roles {
      allow read, write: if isAdmin();
    }

    // ============================================
    // DENY ALL OTHER BY DEFAULT
    // ============================================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
