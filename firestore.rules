rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ============================================
    // HELPER FUNCTIONS
    // ============================================
    
    // Check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Get user email
    function getUserEmail() {
      return request.auth.token.email;
    }

    // Check if authenticated user has an email claim
    function hasEmail() {
      return isAuthenticated() && request.auth.token.email != null;
    }
    
    // Check if user is admin via Custom Claims OR Whitelist (Dual Stack)
    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.role == 'admin' ||
        getUserEmail() in [
          'daniel.opazo@hospitalhangaroa.cl',
          'd.opazo.damiani@gmail.com',
          'd.opazo.damiani@hospitalhangaroa.cl',
          'danielopazodamiani@gmail.com'
        ]
      );
    }
    
    // Check if user is nurse via Custom Claims OR Whitelist
    function isNurse() {
      return isAuthenticated() && (
        request.auth.token.role == 'nurse_hospital' || 
        request.auth.token.role == 'admin' ||
        getUserEmail() in [
          'hospitalizados@hospitalhangaroa.cl',
          'enfermeria.hospitalizados@hospitalhangaroa.cl'
        ]
      );
    }

    // Check if user is doctor via Custom Claims OR dynamic role map
    function isDoctor() {
      return isAuthenticated() && (
        request.auth.token.role == 'doctor_urgency' ||
        request.auth.token.role == 'admin' ||
        (
          hasEmail() &&
          exists(/databases/$(database)/documents/config/roles) &&
          get(/databases/$(database)/documents/config/roles).data[getUserEmail()] == 'doctor_urgency'
        )
      );
    }
    
    // Check if user can edit (admin or nurse)
    function canEdit() {
      return isAdmin() || isNurse();
    }

    // Legacy/custom-claim role gate (prevents any random authenticated user access)
    function hasRoleClaim() {
      return isAuthenticated() && request.auth.token.role in [
        'admin',
        'nurse_hospital',
        'doctor_urgency',
        'viewer',
        'viewer_census',
        'editor'
      ];
    }

    // Dynamic role map (config/roles)
    function hasConfiguredRole() {
      return hasEmail() &&
             exists(/databases/$(database)/documents/config/roles) &&
             get(/databases/$(database)/documents/config/roles).data[getUserEmail()] != null;
    }

    // Shared census allowlist by email (doc id = normalized email)
    function hasCensusAuthorizedEmail() {
      return hasEmail() &&
             exists(/databases/$(database)/documents/census-authorized-emails/$(getUserEmail()));
    }

    // Shared census static allowlist fallback (for migrations without Firestore docs yet)
    function hasCensusStaticAllowlistEmail() {
      return hasEmail() &&
             getUserEmail() in [
               'arenka.palma@hospitalhangaroa.cl',
               'natalia.arzola@hospitalhangaroa.cl',
               'vaitiare.hereveri@hospitalhangaroa.cl',
               'kaany.pakomio@hospitalhangaroa.cl',
               'claudia.salgado@hospitalhangaroa.cl',
               'bianca.atam@hospitalhangaroa.cl',
               'ana.pont@hospitalhangaroa.cl',
               'katherin.pont@hospitalhangaroa.cl',
               'eyleen.cisternas@hospitalhangaroa.cl',
               'marco.ramirez@hospitalhangaroa.cl',
               'josemiguel.villavicencio@hospitalhangaroa.cl',
               'carla.curinao@hospitalhangaroa.cl',
               'epidemiologia@hospitalhangaroa.cl',
               'archivosome@hospitalhangaroa.cl',
               'antonio.espinoza@hospitalhangaroa.cl',
               'juan.pakomio@hospitalhangaroa.cl',
               'ivan.pulgar@hospitalhangaroa.cl',
               'daniel.opazo@hospitalhangaroa.cl',
               'andrea.saldana@saludoriente.cl',
               'patricio.medina@saludoriente.cl',
               'gestion.camas@saludoriente.cl',
               'd.opazo.damiani@gmail.com',
               'd.opazo.damiani@hospitalhangaroa.cl'
             ];
    }

    // Consolidated read access for clinical data
    function canReadClinicalData() {
      return isAdmin() ||
             isNurse() ||
             hasRoleClaim() ||
             hasConfiguredRole() ||
             hasCensusAuthorizedEmail() ||
             hasCensusStaticAllowlistEmail();
    }

    // Shared census access logs must represent current caller only.
    function isValidCensusAccessLogCreate() {
      return isAuthenticated() &&
             hasEmail() &&
             request.resource.data.keys().hasOnly(['userId', 'email', 'action', 'filePath', 'fileName', 'timestamp', 'userAgent']) &&
             request.resource.data.userId == request.auth.uid &&
             request.resource.data.email == getUserEmail() &&
             request.resource.data.action in ['list_files', 'download_file', 'view_file'];
    }
    
    // Check if a date (ms timestamp) is within the editing window (+/- 1 day)
    // Nurse window: Can edit yesterday, today and tomorrow.
    // Calculation: (CurrentTime - RecordTime) should be between -24h and +48h
    // If dateTimestamp is null (legacy record), allow the edit (grace mode)
    function isWithinEditingWindow(recordTS) {
      let now = request.time.toMillis();
      // Legacy records without dateTimestamp are allowed (they'll be fixed on save)
      return recordTS == null || (
             now > (recordTS - 86400000) && 
             now < (recordTS + 172800000)
      );
    }

    // Check if the record is for the current calendar day
    // This allows a 24-hour window from the record's start timestamp
    function isCurrentDay(recordTS) {
      let now = request.time.toMillis();
      return recordTS != null && (
             now >= recordTS && 
             now < (recordTS + 86400000)
      );
    }

    // Check if the update is only for medical signature fields
    function isMedicalUpdate() {
      let affectedKeys = request.resource.data.diff(resource.data).affectedKeys();
      return affectedKeys.hasOnly(['medicalSignature', 'medicalHandoffDoctor', 'medicalHandoffSentAt', 'lastUpdated']);
    }
    
    // ============================================
    // HOSPITALS COLLECTION (Main hierarchy)
    // ============================================
    match /hospitals/{hospitalId} {
      // Hospital document itself
      allow read: if canReadClinicalData();
      allow write: if isAdmin();
      
      // ----------------------------------------
      // DAILY RECORDS (Census Data)
      // ----------------------------------------
      match /dailyRecords/{date} {
        allow read: if canReadClinicalData();
        // Create: Admin or Nurse
        allow create: if canEdit();
        // Update: Admin siempre, Enfermero en ventana, o Médico solo campos de firma
        allow update: if isAdmin() || 
                        (isNurse() && isWithinEditingWindow(resource.data.dateTimestamp)) ||
                        (isDoctor() && isMedicalUpdate());
        // Delete: Admin only (nurses must not hard-delete census records)
        allow delete: if isAdmin();
        
        // History subcollection
        match /history/{historyId} {
          allow read: if canReadClinicalData();
          allow create: if canEdit();
          allow update, delete: if isAdmin();
        }
      }

      // Deleted Records (Trash)
      match /deletedRecords/{trashId} {
        allow read, write: if isAdmin();
      }
      
      // ----------------------------------------
      // SETTINGS (Nurses, TENS, TableConfig)
      // ----------------------------------------
      match /settings/{settingId} {
        allow read: if canReadClinicalData();
        // Allow both Admins and Nurses to update catalogs and settings
        allow write: if canEdit();
      }
      
      // ----------------------------------------
      // EXPORT PASSWORDS
      // ----------------------------------------
      match /exportPasswords/{passwordId} {
        allow read: if canReadClinicalData();
        allow write: if isAdmin();
      }
      
      // ----------------------------------------
      // AUDIT LOGS (Hospital-level)
      // ----------------------------------------
      match /auditLogs/{logId} {
        allow read: if isAdmin();
        allow create: if canReadClinicalData();
        // Allow admins to update or delete during consolidation/maintenance
        allow update, delete: if isAdmin();
      }
      
      // ----------------------------------------
      // TRANSFER REQUESTS (Patient transfers)
      // ----------------------------------------
      match /transferRequests/{transferId} {
        allow read: if canReadClinicalData();
        allow create: if canEdit();
        allow update: if canEdit();
        allow delete: if isAdmin();
      }
      
      // ----------------------------------------
      // TRANSFER HISTORY (Completed transfers)
      // ----------------------------------------
      match /transferHistory/{transferId} {
        allow read: if canReadClinicalData();
        allow create: if canEdit();
        allow update, delete: if isAdmin();
      }
      
      // ----------------------------------------
      match /bookmarks/{bookmarkId} {
        allow read: if canReadClinicalData();
        allow write: if canReadClinicalData();
      }

      // ----------------------------------------
      // BACKUP FILES (Cloud backup archives)
      // ----------------------------------------
      match /backupFiles/{fileId} {
        allow read: if canReadClinicalData();
        allow create: if canEdit();
        allow update: if isAdmin();
        allow delete: if isAdmin();
      }

      // ----------------------------------------
      // PATIENT MASTER INDEX
      // ----------------------------------------
      match /patients/{rut} {
        allow read: if canReadClinicalData();
        allow write: if canEdit();
      }
    }
    
    // ============================================
    // TOP-LEVEL AUDIT LOGS (Legacy/Fallback)
    // ============================================
    match /auditLogs/{logId} {
      allow read: if isAdmin();
      allow create: if canReadClinicalData();
      // Allow admins to update or delete during consolidation/maintenance
      allow update, delete: if isAdmin();
    }
    
    // ============================================
    // ALLOWED USERS (Admin management)
    // ============================================
    match /allowedUsers/{userId} {
      // Whitelist Read-Lock fix: Allow users to read their own authorization doc 
      // or search for it by email to validate their role.
      allow read: if isAuthenticated() && (
        request.auth.uid == userId || 
        resource.data.email == getUserEmail() ||
        isAdmin()
      );
      allow write: if isAdmin();
    }
    
    // ============================================
    // STAFF CATALOGS (Legacy - if still used)
    // ============================================
    match /staffCatalogs/{catalogType} {
      allow read: if canReadClinicalData();
      allow write: if isAdmin();
    }
    
    // ============================================
    // USER SETTINGS
    // ============================================
    match /userSettings/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow write: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
    }
    
    // ============================================
    // WHATSAPP INTEGRATION
    // ============================================
    match /whatsapp/{docId} {
      allow read: if canReadClinicalData();
      allow write: if isAdmin();
    }
    
    match /whatsappLogs/{logId} {
      allow read: if isAdmin();
      allow create: if canReadClinicalData();
      allow update, delete: if false;
    }
    
    match /whatsappMessages/{messageId} {
      allow read, write: if isAdmin();
    }
    
    match /shifts/{path=**} {
      allow read: if canReadClinicalData();
      allow write: if isAdmin();
    }
    
    // ============================================
    // CENSUS ACCESS (Shared census links)
    // ============================================
    match /census-access-invitations/{invitationId} {
      allow read: if canEdit() || (
        isAuthenticated() &&
        (
          resource.data.email == null ||
          (hasEmail() && resource.data.email == getUserEmail())
        )
      );
      allow create: if canEdit();
      allow update: if canEdit() || (
        isAuthenticated() &&
        resource.data.status == 'pending' &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'usedBy', 'usedAt']) &&
        request.resource.data.status == 'used' &&
        request.resource.data.usedBy == request.auth.uid &&
        (
          resource.data.email == null ||
          (hasEmail() && resource.data.email == getUserEmail())
        )
      );
      allow delete: if isAdmin();
    }
    
    match /census-access-users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || canEdit());
      allow create, update: if canEdit();
      allow delete: if isAdmin();
    }
    
    match /census-access-logs/{logId} {
      allow read: if canEdit();
      allow create: if isValidCensusAccessLogCreate();
    }
    
    match /census-authorized-emails/{email} {
      allow read: if canEdit();
      allow write: if canEdit();
    }

    // ============================================
    // SYSTEM HEALTH
    // ============================================
    match /stats/system_health/users/{userId} {
      allow read: if isAdmin();
      allow write: if isAuthenticated() && request.auth.uid == userId;
    }

    // ============================================
    // SYSTEM CONFIGURATION
    // ============================================
    match /config/roles {
      allow read, write: if isAdmin();
    }

    // ============================================
    // DENY ALL OTHER BY DEFAULT
    // ============================================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
