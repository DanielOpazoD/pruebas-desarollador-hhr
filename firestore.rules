rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ============================================
    // HELPER FUNCTIONS
    // ============================================
    
    // Check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Get user email
    function getUserEmail() {
      return request.auth.token.email;
    }
    
    // Check if user is admin via Custom Claims OR Whitelist (Dual Stack)
    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.role == 'admin' ||
        getUserEmail() in [
          'daniel.opazo@hospitalhangaroa.cl',
          'd.opazo.damiani@gmail.com',
          'd.opazo.damiani@hospitalhangaroa.cl',
          'danielopazodamiani@gmail.com'
        ]
      );
    }
    
    // Check if user is nurse via Custom Claims OR Whitelist
    function isNurse() {
      return isAuthenticated() && (
        request.auth.token.role == 'nurse_hospital' || 
        request.auth.token.role == 'admin' ||
        getUserEmail() in [
          'hospitalizados@hospitalhangaroa.cl',
          'enfermeria.hospitalizados@hospitalhangaroa.cl'
        ]
      );
    }
    
    // Check if user can edit (admin or nurse)
    function canEdit() {
      return isAdmin() || isNurse();
    }
    
    // Check if a date (ms timestamp) is within the editing window (+/- 1 day)
    // Nurse window: Can edit yesterday, today and tomorrow.
    // Calculation: (CurrentTime - RecordTime) should be between -24h and +48h
    // If dateTimestamp is null (legacy record), allow the edit (grace mode)
    function isWithinEditingWindow(recordTS) {
      let now = request.time.toMillis();
      // Legacy records without dateTimestamp are allowed (they'll be fixed on save)
      return recordTS == null || (
             now > (recordTS - 86400000) && 
             now < (recordTS + 172800000)
      );
    }

    // Check if the update is only for medical signature fields
    function isMedicalUpdate() {
      let affectedKeys = request.resource.data.diff(resource.data).affectedKeys();
      return affectedKeys.hasOnly(['medicalSignature', 'medicalHandoffDoctor', 'medicalHandoffSentAt', 'lastUpdated']);
    }
    
    // ============================================
    // HOSPITALS COLLECTION (Main hierarchy)
    // ============================================
    match /hospitals/{hospitalId} {
      // Hospital document itself
      allow read: if isAuthenticated();
      allow write: if isAdmin();
      
      // ----------------------------------------
      // DAILY RECORDS (Census Data)
      // ----------------------------------------
      match /dailyRecords/{date} {
        allow read: if isAuthenticated();
        // Create: Admin or Nurse
        allow create: if canEdit();
        // Update: Admin siempre, Enfermero en ventana, o Médico solo campos de firma
        allow update: if isAdmin() || 
                        (isNurse() && isWithinEditingWindow(resource.data.dateTimestamp)) ||
                        (isAuthenticated() && isMedicalUpdate());
        // Delete: Admin only
        allow delete: if isAdmin();
        
        // History subcollection
        match /history/{historyId} {
          allow read: if isAuthenticated();
          allow create: if isAuthenticated();
          allow update, delete: if isAdmin();
        }
      }

      // Deleted Records (Trash)
      match /deletedRecords/{trashId} {
        allow read, write: if isAdmin();
      }
      
      // ----------------------------------------
      // SETTINGS (Nurses, TENS, TableConfig)
      // ----------------------------------------
      match /settings/{settingId} {
        allow read: if isAuthenticated();
        allow write: if isAdmin();
      }
      
      // ----------------------------------------
      // EXPORT PASSWORDS
      // ----------------------------------------
      match /exportPasswords/{passwordId} {
        allow read: if isAuthenticated();
        allow write: if isAdmin();
      }
      
      // ----------------------------------------
      // AUDIT LOGS (Hospital-level)
      // ----------------------------------------
      match /auditLogs/{logId} {
        allow read: if isAdmin();
        allow create: if isAuthenticated();
        // Allow admins to update or delete during consolidation/maintenance
        allow update, delete: if isAdmin();
      }
      
      // ----------------------------------------
      // TRANSFER REQUESTS (Patient transfers)
      // ----------------------------------------
      match /transferRequests/{transferId} {
        allow read: if isAuthenticated();
        allow create: if canEdit();
        allow update: if canEdit();
        allow delete: if isAdmin();
      }
      
      // ----------------------------------------
      // TRANSFER HISTORY (Completed transfers)
      // ----------------------------------------
      match /transferHistory/{transferId} {
        allow read: if isAuthenticated();
        allow create: if canEdit();
        allow update, delete: if isAdmin();
      }
      
      // ----------------------------------------
      match /bookmarks/{bookmarkId} {
        allow read: if true;
        allow write: if request.auth != null;
      }

      // ----------------------------------------
      // BACKUP FILES (Cloud backup archives)
      // ----------------------------------------
      match /backupFiles/{fileId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated();  // Temporarily allow all authenticated users for testing
        allow update: if isAdmin();
        allow delete: if isAdmin();
      }

      // ----------------------------------------
      // PATIENT MASTER INDEX
      // ----------------------------------------
      match /patients/{rut} {
        allow read: if isAuthenticated();
        allow write: if canEdit();
      }
    }
    
    // ============================================
    // TOP-LEVEL AUDIT LOGS (Legacy/Fallback)
    // ============================================
    match /auditLogs/{logId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();
      // Allow admins to update or delete during consolidation/maintenance
      allow update, delete: if isAdmin();
    }
    
    // ============================================
    // ALLOWED USERS (Admin management)
    // ============================================
    match /allowedUsers/{userId} {
      // Whitelist Read-Lock fix: Allow users to read their own authorization doc 
      // or search for it by email to validate their role.
      allow read: if isAuthenticated() && (
        request.auth.uid == userId || 
        resource.data.email == getUserEmail() ||
        isAdmin()
      );
      allow write: if isAdmin();
    }
    
    // ============================================
    // STAFF CATALOGS (Legacy - if still used)
    // ============================================
    match /staffCatalogs/{catalogType} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    
    // ============================================
    // USER SETTINGS
    // ============================================
    match /userSettings/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow write: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
    }
    
    // ============================================
    // WHATSAPP INTEGRATION
    // ============================================
    match /whatsapp/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    
    match /whatsappLogs/{logId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();
      allow update, delete: if false;
    }
    
    match /whatsappMessages/{messageId} {
      allow read, write: if isAdmin();
    }
    
    match /shifts/{path=**} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    
    // ============================================
    // CENSUS ACCESS (Shared census links)
    // ============================================
    match /census-access-invitations/{invitationId} {
      allow read: if true; 
      allow write: if isAuthenticated(); // Simplified for debugging
    }
    
    match /census-access-users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update, delete: if canEdit();
    }
    
    match /census-access-logs/{logId} {
      allow read: if canEdit();
      allow create: if isAuthenticated();
    }
    
    match /census-authorized-emails/{email} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated(); // Simplified for debugging
    }

    // ============================================
    // SYSTEM HEALTH
    // ============================================
    match /stats/system_health/users/{userId} {
      allow read: if isAdmin();
      allow write: if isAuthenticated() && request.auth.uid == userId;
    }

    // ============================================
    // SYSTEM CONFIGURATION
    // ============================================
    match /config/roles {
      allow read, write: if isAdmin();
    }

    // ============================================
    // DENY ALL OTHER BY DEFAULT
    // ============================================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

