{
    "$schema": "https://typedoc.org/schema.json",
    "entryPoints": [
        "src/hooks",
        "src/services/repositories",
        "src/services/storage",
        "src/types",
        "src/utils"
    ],
    "entryPointStrategy": "expand",
    "out": "./docs/api",
    "name": "HHR Hospitalizados - API Documentation",
    "readme": "./README.md",
    "excludePrivate": true,
    "excludeInternal": true,
    "includeVersion": true,
    "skipErrorChecking": true,
    "navigationLinks": {
        "GitHub": "https://github.com/DanielOpazoD/HospitalizadosHHR"
    },
    "plugin": [],
    "theme": "default",
    "validation": {
        "notExported": true,
        "invalidLink": true,
        "notDocumented": false
    }
}