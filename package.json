    "report:operational-health": "node scripts/report-operational-health.mjs",
    "report:system-confidence": "node scripts/report-system-confidence.mjs",
    "report:legacy-bridge": "node scripts/report-legacy-bridge.mjs",
    "report:compatibility-governance": "node scripts/report-compatibility-governance.mjs",
    "report:architectural-hotspots": "node scripts/report-architectural-hotspots.mjs",
    "report:runtime-contracts": "node scripts/report-runtime-contracts.mjs",
