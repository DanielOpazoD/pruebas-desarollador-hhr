    "test:e2e:ui": "playwright test --ui",
    "test:e2e:critical": "unset NO_COLOR; playwright test -c playwright.emulator-critical.config.ts e2e/critical-emulator.spec.ts e2e/auth-multi-tab-lock.spec.ts e2e/auth-login-resilience.spec.ts e2e/startup-performance-budget.spec.ts",
    "test:e2e:flow-performance": "unset NO_COLOR; playwright test -c playwright.emulator-critical.config.ts e2e/startup-performance-budget.spec.ts",
    "test:e2e:critical:ci": "bash scripts/run-e2e-critical-emulator-ci.sh",
    "test:vrt": "playwright test e2e/visual-regression.spec.ts",
    "test:vrt:update": "playwright test e2e/visual-regression.spec.ts --update-snapshots",
    "test:send-email": "node --loader ts-node/esm scripts/testSendCensusEmail.ts",
