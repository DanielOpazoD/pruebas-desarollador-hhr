{
  "name": "hanga-roa-hospital-tracker",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "npm run test:ci:unit && npm run test:rules:ci && npm run test:emulator:sync:ci",
