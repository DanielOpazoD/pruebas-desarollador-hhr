    "test:coverage": "vitest run --coverage",
    "test:coverage:critical": "node scripts/run-critical-coverage.mjs",
    "test:smoke:critical-runtime": "node scripts/run-critical-smoke-pack.mjs",
    "test:release-confidence": "node scripts/run-release-confidence-pack.mjs --profile blocking",
    "test:release-confidence:full": "node scripts/run-release-confidence-pack.mjs --profile full",
    "test:clinical-documents": "vitest run src/tests/features/clinical-documents src/tests/services/repositories/ClinicalDocumentRepository.test.ts",
