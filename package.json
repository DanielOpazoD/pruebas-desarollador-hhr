{
  "name": "hanga-roa-hospital-tracker",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:ci:unit": "vitest run --exclude src/tests/security/firestore-rules.test.ts",
    "test:resilience": "vitest run src/tests/integration/sync-resilience.test.ts src/tests/integration/sync-ui-resilience.test.tsx src/tests/integration/offline-persistence.test.ts",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:vrt": "playwright test e2e/visual-regression.spec.ts",
    "test:vrt:update": "playwright test e2e/visual-regression.spec.ts --update-snapshots",
    "test:send-email": "node --loader ts-node/esm scripts/testSendCensusEmail.ts",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "prepare": "husky",
    "docs:generate": "typedoc",
    "lint": "eslint . --report-unused-disable-directives --max-warnings 1500",
    "lint:fix": "eslint . --fix",
    "check:architecture": "node scripts/check-architecture.mjs",
    "check:feature-dependencies": "node scripts/check-feature-dependencies.mjs",
    "check:shared-layer-boundary": "node scripts/check-shared-layer-boundary.mjs",
    "check:legacy-localstorage-imports": "node scripts/check-localstorage-legacy-imports.mjs",
    "check:schema-governance": "node scripts/check-schema-governance.mjs",
    "check:folder-dependencies": "node scripts/check-folder-dependencies.mjs",
    "check:module-dependencies": "node scripts/check-module-dependencies.mjs",
    "check:module-size": "node scripts/check-module-size.mjs",
    "check:census-runtime-boundary": "node scripts/check-census-runtime-boundary.mjs",
    "check:runtime-adapter-boundary": "node scripts/check-runtime-adapter-boundary.mjs",
    "check:test-governance": "node scripts/check-test-governance.mjs",
    "check:secret-leaks": "node scripts/check-secret-leaks.mjs",
    "check:security": "npm run check:secret-leaks && node scripts/check-security-hardening.mjs",
    "report:dependency-debt": "node scripts/report-folder-dependency-debt.mjs",
    "check:quality": "npm run check:architecture && npm run check:feature-dependencies && npm run check:shared-layer-boundary && npm run check:legacy-localstorage-imports && npm run check:schema-governance && npm run check:folder-dependencies && npm run check:module-dependencies && npm run check:module-size && npm run check:census-runtime-boundary && npm run check:runtime-adapter-boundary && npm run check:test-governance && npm run check:security",
    "clean": "bash scripts/cleanup.sh",
    "ci": "npm run check:quality && npm run lint && npm run test && npm run build",
    "ci:strict": "npm run check:quality && npm run lint -- --max-warnings 0 && npm run typecheck && npm run test:ci:unit && npm run test:rules:ci && npm run build",
    "typecheck": "tsc --noEmit --skipLibCheck -p tsconfig.json",
    "test:rules": "RUN_FIRESTORE_RULES_TESTS=1 vitest run src/tests/security/firestore-rules.test.ts",
    "test:rules:ci": "bash scripts/run-firestore-rules-ci.sh",
    "emulator": "firebase emulators:start --only firestore"
  },
  "dependencies": {
    "@google/genai": "^1.31.0",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@tanstack/react-query": "^5.90.12",
    "@tanstack/react-virtual": "^3.13.13",
    "@types/file-saver": "^2.0.7",
    "@types/three": "^0.182.0",
    "clsx": "^2.1.1",
    "dexie": "^4.2.1",
    "docx": "^9.5.1",
    "docxtemplater": "^3.67.6",
    "exceljs": "^4.4.0",
    "file-saver": "^2.0.5",
    "firebase": "^12.6.0",
    "googleapis": "^144.0.0",
    "jspdf": "^4.1.0",
    "jspdf-autotable": "^5.0.2",
    "lucide-react": "^0.556.0",
    "pizzip": "^3.2.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-error-boundary": "^6.0.0",
    "react-is": "^19.2.3",
    "react-use": "^17.6.0",
    "recharts": "^3.5.1",
    "three": "^0.182.0",
    "xlsx-populate": "^1.21.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^4.1.3",
    "@eslint/js": "^9.39.2",
    "@firebase/rules-unit-testing": "^5.0.0",
    "@playwright/test": "^1.57.0",
    "@storybook/addon-a11y": "^10.2.9",
    "@storybook/addon-docs": "^10.2.9",
    "@storybook/addon-onboarding": "^10.2.9",
    "@storybook/addon-vitest": "^10.2.9",
    "@storybook/react-vite": "^10.2.9",
    "@tailwindcss/vite": "^4.1.18",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/jspdf": "^1.3.3",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.2",
    "@vitest/browser-playwright": "^4.0.15",
    "@vitest/coverage-v8": "^4.0.15",
    "autoprefixer": "^10.4.23",
    "eslint": "^9.39.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-storybook": "^10.2.9",
    "fake-indexeddb": "^6.2.5",
    "globals": "^17.0.0",
    "husky": "^9.1.7",
    "jsdom": "^27.3.0",
    "lint-staged": "^16.2.7",
    "playwright": "^1.57.0",
    "postcss": "^8.5.6",
    "prettier": "^3.8.1",
    "storybook": "^10.2.9",
    "tailwindcss": "^4.1.18",
    "ts-node": "^1.7.1",
    "typedoc": "^0.28.15",
    "typescript": "~5.8.2",
    "typescript-eslint": "^8.56.0",
    "vite": "^6.2.0",
    "vite-plugin-compression": "^0.5.1",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.0.15",
    "workbox-expiration": "^7.4.0",
    "workbox-precaching": "^7.4.0",
    "workbox-routing": "^7.4.0",
    "workbox-strategies": "^7.4.0"
  },
  "overrides": {
    "lodash": "4.17.23",
    "qs": "6.15.0",
    "@isaacs/brace-expansion": "5.0.1",
    "markdown-it": "14.1.1"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,css,md}": [
      "npm exec -- prettier --write --ignore-unknown"
    ]
  }
}
