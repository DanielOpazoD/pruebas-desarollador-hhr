    "ci:merge-gate": "npm run typecheck && npm run lint -- --max-warnings 0 && npm run lint:strict:core && npm run check:quality && npm run test:ci:unit && npm run check:critical-coverage && npm run build && npm run check:bundle-budget",
    "ci:release-gate": "npm run ci:merge-gate && npm run test:firestore:release:ci",
    "clean": "bash scripts/cleanup.sh",
    "ci": "npm run ci:merge-gate",
    "ci:quality-core": "npm run ci:inner-loop",
    "ci:strict": "npm run ci:release-gate",
    "typecheck": "tsc --noEmit --skipLibCheck -p tsconfig.json",
    "test:rules": "RUN_FIRESTORE_RULES_TESTS=1 vitest run -c vitest.rules.config.ts src/tests/security/firestore-rules.test.ts",
    "test:rules:ci": "bash scripts/run-firestore-rules-ci.sh",
    "test:emulator:sync": "RUN_FIRESTORE_EMULATOR_TESTS=1 vitest run -c vitest.emulator.config.ts",
    "test:emulator:ui": "RUN_FIRESTORE_EMULATOR_TESTS=1 vitest run -c vitest.emulator-ui.config.ts",
    "test:emulator:sync:ci": "bash scripts/run-firestore-sync-emulator-ci.sh",
    "test:firestore:release:ci": "bash scripts/run-firestore-release-gate-ci.sh",
    "emulator": "firebase emulators:start --only firestore"
