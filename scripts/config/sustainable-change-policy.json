{
  "version": 1,
  "changeTypes": [
    {
      "id": "safe_local_ui",
      "label": "UI local, copy o estilos sin impacto runtime",
      "requiredGates": ["ci:inner-loop"],
      "requiredDocs": ["docs/SAFE_CHANGE_CHECKLIST.md"],
      "requiredArtifacts": []
    },
    {
      "id": "critical_runtime",
      "label": "Runtime critico: auth, storage, sync, bootstrap",
      "requiredGates": ["ci:merge-gate", "test:release-confidence"],
      "requiredDocs": [
        "docs/CI_GATES_AND_FAILURE_RUNBOOKS.md",
        "docs/ENGINEERING_DEFINITION_OF_DONE.md"
      ],
      "requiredArtifacts": ["reports/release-readiness-scorecard.md"]
    },
    {
      "id": "firestore_release",
      "label": "Firestore rules, emulador o release critico",
      "requiredGates": ["ci:release-gate", "test:release-confidence"],
      "requiredDocs": ["docs/FIREBASE_POLICY.md", "docs/RUNBOOK_SYNC_RESILIENCE.md"],
      "requiredArtifacts": ["reports/release-readiness-scorecard.md"]
    },
    {
      "id": "architecture_contracts",
      "label": "Arquitectura, boundaries, contratos o entrypoints publicos",
      "requiredGates": ["check:quality", "ci:merge-gate"],
      "requiredDocs": [
        "docs/architecture.md",
        "docs/QUALITY_GUARDRAILS.md",
        "docs/ENGINEERING_DEFINITION_OF_DONE.md"
      ],
      "requiredArtifacts": []
    },
    {
      "id": "foundations_convergence",
      "label": "Convergencia estructural: shims, APIs publicas, megatests y hygiene",
      "requiredGates": ["check:repo-hygiene", "lint", "typecheck"],
      "requiredDocs": [
        "docs/FOUNDATION_TRACKER.md",
        "docs/FOUNDATION_MAINTENANCE_CADENCE.md",
        "docs/QUALITY_GUARDRAILS.md"
      ],
      "requiredArtifacts": ["reports/quality-metrics.md", "reports/technical-execution-baseline.md"]
    },
    {
      "id": "dependency_upgrade",
      "label": "Upgrade de dependencias o toolchain",
      "requiredGates": ["typecheck", "lint", "ci:merge-gate"],
      "requiredDocs": ["docs/SAFE_CHANGE_CHECKLIST.md", "docs/QUALITY_GUARDRAILS.md"],
      "requiredArtifacts": ["reports/release-readiness-scorecard.md"]
    }
  ],
  "dependencyUpgrades": {
    "requiredFields": [
      "owner",
      "reason",
      "targetVersion",
      "riskLevel",
      "rollbackPlan",
      "verificationGate"
    ],
    "categories": [
      {
        "id": "firebase_runtime",
        "requiredGates": ["ci:release-gate", "test:release-confidence"],
        "requiredDocs": ["docs/FIREBASE_POLICY.md", "docs/RUNBOOK_AUTH_ACCESS_INCIDENTS.md"]
      },
      {
        "id": "build_tooling",
        "requiredGates": ["typecheck", "lint", "ci:merge-gate"],
        "requiredDocs": ["docs/QUALITY_GUARDRAILS.md"]
      },
      {
        "id": "clinical_pdf_export",
        "requiredGates": ["ci:merge-gate", "test:release-confidence"],
        "requiredDocs": ["docs/RUNBOOK_SUPPORT_OPERATIONS.md"]
      }
    ]
  },
  "guardrailExceptions": {
    "requiredFields": ["owner", "reason", "closureCriteria", "expiresAt", "trackedIn"],
    "governedAllowlists": [
      "scripts/module-size-allowlist.json",
      "scripts/hook-hotspots-limits.json",
      "scripts/config/test-failure-catalog.json",
      "scripts/config/flaky-quarantine.json",
      "scripts/config/compatibility-governance.json"
    ],
    "escalationGate": "check:quality"
  },
  "definitionOfDone": {
    "requiredChecks": ["typecheck", "lint", "check:quality", "build"],
    "requiredDocs": ["docs/ENGINEERING_DEFINITION_OF_DONE.md", "docs/SAFE_CHANGE_CHECKLIST.md"],
    "releaseScorecard": "reports/release-readiness-scorecard.md"
  }
}
