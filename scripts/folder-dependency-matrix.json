      "responsibility": "Reusable UI composition and presentation.",
      "allowedDependencies": [
        "hooks",
        "context",
        "services",
        "types",
        "constants",
        "utils",
        "shared",
        "schemas",
        "core"
      ]
    },
    "hooks": {
      "responsibility": "Reusable behavior and UI orchestration hooks.",
      "allowedDependencies": [
        "domain",
        "services",
        "context",
        "types",
        "constants",
        "utils",
