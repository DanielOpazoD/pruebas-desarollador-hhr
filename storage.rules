rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isAuthenticated() {
      return request.auth != null;
    }

    function hasEmail() {
      return isAuthenticated() && request.auth.token.email != null;
    }

    function userEmail() {
      return request.auth.token.email;
    }

    function isBootstrapAdmin() {
      return hasEmail() && userEmail() in [
        'daniel.opazo@hospitalhangaroa.cl',
        'd.opazo.damiani@gmail.com',
        'd.opazo.damiani@hospitalhangaroa.cl'
      ];
    }

    function normalizedRole() {
      return !isAuthenticated() || request.auth.token.role == null
        ? null
        : request.auth.token.role == 'viewer_census'
          ? 'viewer'
          : request.auth.token.role;
    }

    function hasClinicalReadRole() {
      return isAuthenticated() && normalizedRole() in [
        'admin',
        'nurse_hospital',
        'doctor_urgency',
        'viewer',
        'editor'
      ];
    }

    function hasClinicalWriteRole() {
      return isAuthenticated() && normalizedRole() in [
        'admin',
        'nurse_hospital',
        'editor'
      ];
    }

    function canWriteReminderAssets() {
      return hasClinicalWriteRole() || isBootstrapAdmin();
    }

    function canReadClinicalStorage() {
      return hasClinicalReadRole();
    }

    // Entrega de enfermería backups: editable only by clinical editors.
    match /entregas-enfermeria/{allPaths=**} {
      allow read: if canReadClinicalStorage();
      allow write: if hasClinicalWriteRole();
    }
    
    // Daily census exports: readable by authenticated clinical users.
    match /censo-diario/{allPaths=**} {
      allow read: if canReadClinicalStorage();
      allow write: if hasClinicalWriteRole();
    }
    
    // Templates can be read by authorized clinical/shared users.
    match /templates/{allPaths=**} {
      allow read: if canReadClinicalStorage();
      allow write: if false;  // Only upload via Firebase Console
    }
    
    // CUDYR monthly backups: editable only by clinical editors.
    match /cudyr-backup/{allPaths=**} {
      allow read: if canReadClinicalStorage();
      allow write: if hasClinicalWriteRole();
    }

    match /reminders/{allPaths=**} {
      allow read: if canReadClinicalStorage();
      allow write: if canWriteReminderAssets();
    }
    
    // Default: deny all other access
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
