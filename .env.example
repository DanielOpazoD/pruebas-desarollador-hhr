# Environment Variables for HHR Hospital Tracker
# Copy this file to .env.local and fill in the values

# ============================================
# Firebase Configuration
# ============================================
# Use plain API key or the optional base64 variant. Production on Netlify
# can rely on runtime config instead of exposing all values in local files.
VITE_FIREBASE_API_KEY=your_firebase_api_key
# VITE_FIREBASE_API_KEY_B64=base64_encoded_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Optional local emulators
# VITE_FUNCTIONS_EMULATOR_HOST=127.0.0.1:5001
# VITE_AUTH_EMULATOR_HOST=http://127.0.0.1:9099
# VITE_FIRESTORE_EMULATOR_HOST=127.0.0.1:8080

# ============================================
# Security Configuration
# ============================================
# Secret key for offline passport signatures (min 32 characters recommended)
# WARNING: This key is visible in the client bundle. For maximum security,
# passport verification should be done server-side via Cloud Functions.
VITE_PASSPORT_SECRET=your-secure-random-key-min-32-chars

# ============================================
# Gmail API (for Netlify Functions only)
# ============================================
# These are NOT prefixed with VITE_ as they are server-side only
# GMAIL_CLIENT_ID=your_gmail_client_id
# GMAIL_CLIENT_SECRET=your_gmail_client_secret
# GMAIL_REFRESH_TOKEN=your_refresh_token

# ============================================
# Local Development Email Flow (optional)
# ============================================
# Keep disabled by default to avoid accidental real email dispatches from localhost.
# Set to true only when intentionally testing end-to-end with local functions.
# VITE_ALLOW_DEV_EMAIL_SEND=false
# Optional override if your local function endpoint differs.
# VITE_CENSUS_EMAIL_ENDPOINT=/.netlify/functions/send-census-email

# ============================================
# Local Development AI Fallback (optional)
# ============================================
# Used only in localhost/dev for CIE-10 AI fallback when Netlify Functions
# are not available. Do not define production Gemini keys as VITE_* values.
# VITE_LOCAL_GEMINI_API_KEY=your_local_dev_only_gemini_key

# ============================================
# Google Drive Editing (optional)
# ============================================
# Required only for "Editar Cloud" in transfer documents.
# Create a Web OAuth Client in Google Cloud and authorize your localhost/Netlify origins.
# VITE_GOOGLE_CLIENT_ID=your_google_oauth_web_client_id.apps.googleusercontent.com

# ============================================
# Auth / Diagnostics Flags (optional)
# ============================================
# VITE_AUTH_PREFER_REDIRECT_ON_LOCALHOST=false
# VITE_AUTH_AUTO_REDIRECT_FALLBACK=true
# VITE_DEBUG_LEGACY_FIREBASE=false
# VITE_DEBUG_REPOSITORY=false
# VITE_WHATSAPP_BOT_URL=https://your-bot.example
